# ─────────────────────────────────────────────────────────────────────────────
# Hatch — env template (placeholders only, never commit real secrets).
# Web (Next.js, :3000) reads apps/web/.env.local:   cp .env.example apps/web/.env.local
# MCP (Railway, :8080) reads apps/mcp/.env:          see apps/mcp/.env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (web) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only — never expose to the client

# ── Wanted feature: agents + semantic matching ──────────────────────────────
ANTHROPIC_API_KEY=                    # Refiner / Parser / Validator / Matcher re-rank (Claude)
VOYAGE_API_KEY=                       # voyage-3 embeddings; absent → matcher falls back to FTS
WANTED_V1_ENABLED=false               # feature flag (global default; per-user override in profiles.feature_flags)

# ── Vercel Cron (auth for /api/cron/*) ───────────────────────────────────────
CRON_SECRET=                          # any random ≥32-char string

# ── Web Push notifications ───────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                    # generate: npx web-push generate-vapid-keys

# ── MCP server URL (used by the /settings/api-keys config snippet) ───────────
NEXT_PUBLIC_MCP_URL=http://localhost:8080/mcp

# ── Optional ─────────────────────────────────────────────────────────────────
# VIEW_HASH_SALT=                     # salt for view-dedup hashing (defaults to 'hatch-view-v1')
# WANTED_EVAL_LIVE=1                  # with ANTHROPIC_API_KEY, runs the env-guarded eval suites

# ─────────────────────────────────────────────────────────────────────────────
# apps/mcp (set on Railway in prod, or copy to apps/mcp/.env for local)
# ─────────────────────────────────────────────────────────────────────────────
PORT=8080
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# LOG_LEVEL=info
